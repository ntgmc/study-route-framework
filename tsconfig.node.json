{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist/server",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/backend/**/*.ts", "src/cli/**/*.ts", "src/shared/**/*.ts", "types/**/*.ts"]
}
